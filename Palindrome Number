import java.util.*;

public class Main {
    public static void main(String[] args) {
      Scanner sc = new Scanner(System.in);
      int a = sc.nextInt();
      int reversed = 0;
      int original = a;
      if (a<0){
        System.out.print(false);
      }else {
        while (a!=0){
          int reminder = a%10;
          a =  a/10;
          reversed = reversed*10 + reminder;
        }
        if ( original == reversed){
            System.out.print(true);
        }else{
            System.out.print(false);
        }

      }

    }
}
